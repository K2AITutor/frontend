EXPO_PUBLIC_API_BASE_URL=http://your-local-ip:4000/api

# PostHog — powers analytics and remote feature flags.
# Leave the key blank to disable PostHog; flags then fall back to their
# code-level defaults in the shared registry
# (packages/shared/src/constants/featureFlags.ts).
#
# For local dev, set the key here. For EAS builds the key is injected from
# EAS environment variables (see eas.json + `eas env:create`), not committed.
EXPO_PUBLIC_POSTHOG_KEY=your-posthog-project-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
